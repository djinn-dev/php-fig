{
    "name": "djinn_dev/php-fig",
    "description": "A fast PHP8 implementation of PHP-Fig interfaces.",
    "version": "0.1",
    "license": "MIT",
    "keywords": [
        "psr-7",
        "psr-17"
    ],
    "homepage": "https://djinn.dev/",
    "authors": [
        {
            "name": "Trevor Geene",
            "email": "trevor.geene@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.1.0"
    },
    "provide": {
        "psr/http-message-implementation": "1.0",
        "psr/http-factory-implementation": "1.0"
    },
    "autoload": {
        "psr-4": {
            "DjinnDev\\Utilities\\": "src/utilities/",
            "DjinnDev\\Psr7\\": "src/psr-7/",
            "DjinnDev\\Psr17\\": "src/psr-17/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
